# Claude / AI assistant context — local only, never track
CLAUDE.md
.claude/
.cursor/
.aider*

# Design / implementation / planning docs — local only
/docs/
docs/*
*.design.md
*.implementation.md

# Security scan output — local only
scans/

# Build output
/dist/
/bin/
/build/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Frontend build output (regenerated by Docker/Vite)
backend/static/

# Frontend
frontend/node_modules/
frontend/dist/
web/node_modules/
web/dist/
web/ui/node_modules/
web/ui/dist/
web/.vite/
*.log
npm-debug.log*

# Firmware binaries — mounted at runtime, not committed
firmware/**/*.bin
